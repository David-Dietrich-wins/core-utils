{
  "name": "@grayarrow/core-utils",
  "version": "3.0.6",
  "description": "Core helper utilities for supporting TypeScript and JavaScript projects.",
  "private": false,
  "main": "dist/index.js",
  "scripts": {
    "build:orig": "rimraf dist && tsc --build",
    "build": "rimraf dist && tsc --build && cp package.json dist/package.json && cp README.md dist/README.md",
    "build2": "rimraf dist && tsc --build && echo '{\"type\":\"module\"}' > dist/package.json && cp README.md dist/README.md",
    "clean": "rimraf coverage dist node_modules yarn.lock package-lock.json",
    "clean:build": "npm run clean && npm install && npm run build",
    "coverage": "jest --coverage",
    "lint": "eslint ./src/ --fix",
    "test:watch": "jest --watch",
    "test2": "jest",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grayarrow/core-utils.git"
  },
  "engines": {
    "node": ">=18.0"
  },
  "keywords": [
    "Intecore",
    "utilities",
    "TypeScript"
  ],
  "author": "David Dietrich",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/grayarrow/core-utils/issues"
  },
  "homepage": "https://github.com/grayarrow/core-utils#readme",
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.7.3",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.57.0",
    "eslint-config-love": "^43.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "msw": "^2.4.9",
    "prettier": "^3.2.5",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "latest"
  },
  "lint-staged": {
    "*.ts": "eslint --cache --cache-location .eslintcache --fix"
  },
  "dependencies": {
    "@azure/eventgrid": "^5.3.0",
    "@azure/functions": "^3.0.0",
    "@azure/identity": "^4.0.1",
    "@azure/keyvault-secrets": "^4.8.0",
    "applicationinsights": "^2.9.5",
    "axios": "^1.7.7",
    "crypto-js": "^4.2.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^10.0.2",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xml2js": "^0.6.2"
  }
}
